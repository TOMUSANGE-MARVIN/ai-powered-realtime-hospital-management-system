# --- MySQL (internal, not exposed publicly) ---
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=hospital
MYSQL_USER=hospital
MYSQL_PASSWORD=change-me

# --- Backend ---
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me
# Public URL of the backend, as reachable from the internet (used for auth callbacks)
BETTER_AUTH_URL=https://api.yourdomain.com
# Public URL of the frontend (used for CORS + auth trusted origins)
FRONTEND_URL=https://app.yourdomain.com

GEMINI_KEY=
UPLOADTHING_TOKEN=

# Optional — leave blank to disable Polar billing features
POLAR_PRODUCT_ID=
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=

# --- Frontend (baked in at build time — must match BETTER_AUTH_URL above) ---
VITE_API_URL=https://api.yourdomain.com
